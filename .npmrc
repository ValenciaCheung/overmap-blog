# pnpm 11+ enforces a 24h "supply-chain" minimum release age by default.
# Several of our deps (wrangler, miniflare, workerd, shadcn) ship daily,
# so any CI install can be blocked just because a release happened today.
#
# Setting this to 0 disables the check entirely. We rely on the lockfile
# (committed) for reproducibility, not on a wall-clock embargo.
minimum-release-age=0

# Allow native deps with install scripts that we approved in pnpm-workspace.yaml
# to actually run their build scripts on CI as well.
auto-install-peers=true
